    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_add_32dp"
        app:backgroundTint="#C30052"
        app:fabSize="normal"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_members_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:layout_constraintBottom_toTopOf="@+id/add_fab"
        app:layout_constraintEnd_toEndOf="@+id/add_fab"
        app:layout_constraintStart_toStartOf="@+id/add_fab"
        app:backgroundTint="@color/blue"
        app:tint="@color/white"
        app:srcCompat="@drawable/ic_saving" />


    <TextView
        android:id="@+id/add_members_action_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textColor="#FFFFFF"
        android:text="Saving"
        android:background="#99000000"
        app:layout_constraintBottom_toBottomOf="@+id/add_members_fab"
        app:layout_constraintEnd_toStartOf="@+id/add_members_fab"
        app:layout_constraintTop_toTopOf="@+id/add_members_fab" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/we_group_data_collection_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        android:tint="@color/white"
        app:tint="@color/white"
        android:textSize="15sp"
        app:layout_constraintBottom_toTopOf="@+id/add_members_fab"
        app:layout_constraintEnd_toEndOf="@+id/add_members_fab"
        app:layout_constraintStart_toStartOf="@+id/add_members_fab"
        app:srcCompat="@drawable/ic_add_loan" />


    <TextView
        android:id="@+id/add_loan_action_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Loan"
        android:background="#99000000"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/we_group_data_collection_fab"
        app:layout_constraintEnd_toStartOf="@+id/we_group_data_collection_fab"
        app:layout_constraintTop_toTopOf="@+id/we_group_data_collection_fab" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_fine_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        android:tint="@color/white"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/we_group_data_collection_fab"
        app:layout_constraintEnd_toEndOf="@+id/we_group_data_collection_fab"
        app:layout_constraintStart_toStartOf="@+id/we_group_data_collection_fab"
        app:srcCompat="@drawable/ic_fine" />

    <!-- Action name text for the Fine button -->
    <TextView
        android:id="@+id/add_fine_action_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Fine"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/add_fine_fab"
        app:layout_constraintEnd_toStartOf="@+id/add_fine_fab"
        app:layout_constraintTop_toTopOf="@+id/add_fine_fab" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_social_fund_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        android:tint="@color/white"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/add_fine_fab"
        app:layout_constraintEnd_toEndOf="@+id/add_fine_fab"
        app:layout_constraintStart_toStartOf="@+id/add_fine_fab"
        app:srcCompat="@drawable/ic_social_fund" />

    <TextView
        android:id="@+id/add_social_fund_action_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Social Fund"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/add_social_fund_fab"
        app:layout_constraintEnd_toStartOf="@+id/add_social_fund_fab"
        app:layout_constraintTop_toTopOf="@+id/add_social_fund_fab" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_cash_book_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        android:tint="@color/white"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/add_social_fund_fab"
        app:layout_constraintEnd_toEndOf="@+id/add_social_fund_fab"
        app:layout_constraintStart_toStartOf="@+id/add_social_fund_fab"
        app:srcCompat="@drawable/ic_payments" />

    <TextView
        android:id="@+id/add_repayment_action_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Repayment"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/add_cash_book_fab"
        app:layout_constraintEnd_toStartOf="@+id/add_cash_book_fab"
        app:layout_constraintTop_toTopOf="@+id/add_cash_book_fab" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_cash_in_box_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/add_cash_book_fab"
        app:layout_constraintEnd_toEndOf="@+id/add_cash_book_fab"
        app:layout_constraintStart_toStartOf="@+id/add_cash_book_fab"
        app:srcCompat="@drawable/ic_info" />

    <TextView
        android:id="@+id/add_iga_action_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="IGA"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/add_cash_in_box_fab"
        app:layout_constraintEnd_toStartOf="@+id/add_cash_in_box_fab"
        app:layout_constraintTop_toTopOf="@+id/add_cash_in_box_fab" />
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarx"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF007F"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="PROFILE"
        app:titleTextColor="#ffff" />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/profile_bk"
        app:layout_constraintTop_toBottomOf="@+id/toolbarx">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_image"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginLeft="5dp"
            android:padding="5dp"
            android:src="@drawable/ic_user"
            app:civ_border_color="#Fff"
            app:civ_border_width="2dp" />
        <TextView
            android:id="@+id/user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We User"
            android:textSize="20dp"
            android:textStyle="bold"
            android:textColor="#FBFBFB"/>
        <TextView
            android:id="@id/user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Id"
            android:textSize="15dp"
            android:textColor="#FBFBFB"/>
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C30052"
        android:elevation="12dp"
        app:tabIndicatorColor="@color/white"
        app:tabTextColor="@color/white"
        app:tabSelectedTextColor="@color/white"
        app:tabMaxWidth="0dp"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
