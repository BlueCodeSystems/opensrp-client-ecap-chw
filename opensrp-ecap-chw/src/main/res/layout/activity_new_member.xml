    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_add_32dp"
        app:backgroundTint="#C30052"
        app:fabSize="normal"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addSocialDiscussionFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:fabSize="normal"
        app:layout_constraintBottom_toTopOf="@+id/add_fab"
        app:layout_constraintEnd_toEndOf="@+id/add_fab"
        app:layout_constraintStart_toStartOf="@+id/add_fab"
        app:backgroundTint="@color/blue"
        app:tint="@color/white"
        app:srcCompat="@drawable/ic_groups" />


    <TextView
        android:id="@+id/addSocialDiscussionActionTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textColor="#FFFFFF"
        android:text="Social Discussions"
        android:background="#99000000"
        app:layout_constraintBottom_toBottomOf="@+id/addSocialDiscussionFab"
        app:layout_constraintEnd_toStartOf="@+id/addSocialDiscussionFab"
        app:layout_constraintTop_toTopOf="@+id/addSocialDiscussionFab" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addIgaFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        android:tint="@color/white"
        app:tint="@color/white"
        android:textSize="15sp"
        app:layout_constraintBottom_toTopOf="@+id/addSocialDiscussionFab"
        app:layout_constraintEnd_toEndOf="@+id/addSocialDiscussionFab"
        app:layout_constraintStart_toStartOf="@+id/addSocialDiscussionFab"
        app:srcCompat="@drawable/ic_info" />


    <TextView
        android:id="@+id/addIgaActionTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="IGA"
        android:background="#99000000"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/addIgaFab"
        app:layout_constraintEnd_toStartOf="@+id/addIgaFab"
        app:layout_constraintTop_toTopOf="@+id/addIgaFab" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addRepaymentsFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        android:tint="@color/white"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/addIgaFab"
        app:layout_constraintEnd_toEndOf="@+id/addIgaFab"
        app:layout_constraintStart_toStartOf="@+id/addIgaFab"
        app:srcCompat="@drawable/ic_payments" />

    <!-- Action name text for the Fine button -->
    <TextView
        android:id="@+id/addRepaymentsActionTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Repayment"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/addRepaymentsFab"
        app:layout_constraintEnd_toStartOf="@+id/addRepaymentsFab"
        app:layout_constraintTop_toTopOf="@+id/addRepaymentsFab" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addFinesFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        android:tint="@color/white"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/addRepaymentsFab"
        app:layout_constraintEnd_toEndOf="@+id/addRepaymentsFab"
        app:layout_constraintStart_toStartOf="@+id/addRepaymentsFab"
        app:srcCompat="@drawable/ic_fine" />

    <TextView
        android:id="@+id/addFinesActionTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Fines"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/addFinesFab"
        app:layout_constraintEnd_toStartOf="@+id/addFinesFab"
        app:layout_constraintTop_toTopOf="@+id/addFinesFab" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addLoanFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        android:tint="@color/white"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/addFinesFab"
        app:layout_constraintEnd_toEndOf="@+id/addFinesFab"
        app:layout_constraintStart_toStartOf="@+id/addFinesFab"
        app:srcCompat="@drawable/ic_add_loan" />

    <TextView
        android:id="@+id/addLoanActionTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Loan"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/addLoanFab"
        app:layout_constraintEnd_toStartOf="@+id/addLoanFab"
        app:layout_constraintTop_toTopOf="@+id/addLoanFab" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addSocialFundFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="normal"
        app:backgroundTint="@color/blue"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/addLoanFab"
        app:layout_constraintEnd_toEndOf="@+id/addLoanFab"
        app:layout_constraintStart_toStartOf="@+id/addLoanFab"
        app:srcCompat="@drawable/ic_social_fund" />

    <TextView
        android:id="@+id/addSocialFundActionTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Social Fund"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/addSocialFundFab"
        app:layout_constraintEnd_toStartOf="@+id/addSocialFundFab"
        app:layout_constraintTop_toTopOf="@+id/addSocialFundFab" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addSavingsFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:backgroundTint="@color/blue"
        app:fabSize="normal"
        app:layout_constraintBottom_toTopOf="@+id/addSocialFundFab"
        app:layout_constraintEnd_toEndOf="@+id/addSocialFundFab"
        app:layout_constraintStart_toStartOf="@+id/addSocialFundFab"
        app:srcCompat="@drawable/ic_saving"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/savingActionTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Savings"
        android:textColor="#FFFFFF"
        android:background="#99000000"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/addSavingsFab"
        app:layout_constraintEnd_toStartOf="@+id/addSavingsFab"
        app:layout_constraintTop_toTopOf="@+id/addSavingsFab" />


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarx"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF007F"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="PROFILE"
        app:titleTextColor="#ffff" />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/profile_bk"
        app:layout_constraintTop_toBottomOf="@+id/toolbarx">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profile_image"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginLeft="5dp"
                android:padding="5dp"
                android:src="@drawable/ic_user"
                app:civ_border_color="#Fff"
                app:civ_border_width="2dp" />

            <TextView
                android:id="@+id/user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We User"
                android:textSize="20dp"
                android:textStyle="bold"
                android:textColor="#FBFBFB"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/profile_image"/>

            <TextView
                android:id="@id/user_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Id"
                android:textSize="15dp"
                android:textColor="#FBFBFB"
                android:layout_below="@id/user_name"
                android:layout_marginTop="4dp"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/profile_image"/>


            <Button
                android:id="@+id/go_to_group_profile"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Group Profile"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/transparent_white_button"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="50dp"/>
        </RelativeLayout>
    </LinearLayout>


    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C30052"
        android:elevation="12dp"
        app:tabIndicatorColor="@color/white"
        app:tabTextColor="@color/white"
        app:tabSelectedTextColor="@color/white"
        app:tabMaxWidth="0dp"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
