<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
tools:context=".activity.UserRegisterActivity">

<LinearLayout
    android:id="@+id/linearLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/profile_bk"
    tools:ignore="MissingConstraints">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_image"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginLeft="5dp"
            android:padding="5dp"
            android:src="@drawable/ic_groups"
            app:civ_border_color="#Fff"
            app:civ_border_width="2dp" />

        <TextView
            android:id="@+id/user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We User"
            android:textSize="20dp"
            android:textStyle="bold"
            android:textColor="#FBFBFB"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/profile_image"/>

        <TextView
            android:id="@id/user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Id"
            android:textSize="15dp"
            android:textColor="#FBFBFB"
            android:layout_below="@id/user_name"
            android:layout_marginTop="4dp"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/profile_image"/>


        <!--            <Button-->
        <!--                android:id="@+id/go_to_register"-->
        <!--                android:layout_width="120dp"-->
        <!--                android:layout_height="wrap_content"-->
        <!--                android:text="We-Register"-->
        <!--                android:layout_alignParentEnd="true"-->
        <!--                android:layout_centerVertical="true"-->
        <!--                android:background="@drawable/transparent_white_button"-->
        <!--                android:textColor="#FFFFFF"-->
        <!--                android:layout_marginEnd="40dp"/>-->
    </RelativeLayout>

</LinearLayout>

<ListView
    android:id="@+id/listView"
    android:layout_width="match_parent"
    android:layout_height="700dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="16dp"
    app:layout_constraintTop_toBottomOf="@+id/linearLayout"
    app:layout_constraintBottom_toTopOf="@+id/conduct_register"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintVertical_bias="0.0"/>

    <Button
        android:id="@+id/conduct_register"
        android:layout_width="242dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/profile_bk"
        android:text="Conduct Register"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
